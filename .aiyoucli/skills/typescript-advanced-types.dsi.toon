  3_mapped_types:
    _desc: "Purpose: Transform existing types by iterating over their properties.. Basic Mapped Type:. Optional Properties:. Key Remapping:. Filtering Properties:"
    code[9]:
      - "type Readonly<T> = {"
      - "readonly [P in keyof T]: T[P];"
      - "};"
      - "interface User {"
      - "id: number;"
      - "name: string;"
      - "}"
