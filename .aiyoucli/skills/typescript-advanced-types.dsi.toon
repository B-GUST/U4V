    code[5]: "type Partial<T> = {","[P in keyof T]?: T[P];","};",type PartialUser = Partial<User>;,"// Type: { id?: number; name?: string; }"
    code[9]:
      - "type Getters<T> = {"
      - "[K in keyof T as `get${Capitalize<string & K>}`]: () => T[K];"
      - "};"
      - "interface Person {"
      - "name: string;"
      - "age: number;"
      - "}"
